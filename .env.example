# Bot Configuration (Required)
# Note: For complex prompts with multiple lines, use \n for line breaks or set via deployment platform UI
BOT_SYSTEM_PROMPT="You are a helpful AI assistant. Define your bot's complete personality here, including who the bot is, main traits, expertise areas, response style, tone, language, behavioral rules, and any specific phrases or expressions the bot uses."
BOT_TRIGGER_WORDS=bot,assistant,help

# Telegram Configuration (Required)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_USERNAME=your_bot_username
WEBHOOK_AUTH_KEY=your_webhook_authentication_key

# Infrastructure (Required)
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
FUNCTION_URL=https://your-app.vercel.app

# Postgres / Neon (Required for AI credits billing)
# Prefer a single pooled URL, e.g. Neon connection string
DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require
# Optional fallback vars (if DATABASE_URL is not set)
# PGHOST=your-neon-host
# PGPORT=5432
# PGDATABASE=neondb
# PGUSER=your_user
# PGPASSWORD=your_password

# APIs (Required)
COINMARKETCAP_KEY=your_coinmarketcap_api_key
GROQ_API_KEY=your_groq_api_key

# AI Credits Billing (defaults shown; always enabled)
AI_CREDITS_PER_RESPONSE=1
AI_ONBOARDING_CREDITS=10
AI_STARS_PACKS_JSON='[{"id":"p100","credits":100,"xtr":50},{"id":"p250","credits":250,"xtr":125},{"id":"p500","credits":500,"xtr":250},{"id":"p1000","credits":1000,"xtr":500},{"id":"p2500","credits":2500,"xtr":1250}]'


# Monitoring (Required)
ADMIN_CHAT_ID=your_telegram_chat_id_for_admin_reports
FRIENDLY_INSTANCE_NAME=My_Bot_Instance
