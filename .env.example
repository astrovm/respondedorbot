# Bot Configuration (Required)
# Note: For complex prompts with multiple lines, use \n for line breaks or set via deployment platform UI
BOT_SYSTEM_PROMPT="You are a helpful AI assistant. Define your bot's complete personality here, including who the bot is, main traits, expertise areas, response style, tone, language, behavioral rules, and any specific phrases or expressions the bot uses."
BOT_TRIGGER_WORDS=bot,assistant,help

# Telegram Configuration (Required)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_USERNAME=your_bot_username

# Infrastructure (Required)
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Supabase Postgres (Required for AI credits billing)
# Use the pooled connection URL from Supabase (port 6543)
SUPABASE_POSTGRES_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# APIs
COINMARKETCAP_KEY=your_coinmarketcap_api_key
# Giphy API key for /gm and /gn commands (good morning/night GIFs)
# Get one free at: https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key
# Optional free-tier Groq key. When set, the bot tries this first and
# falls back to GROQ_API_KEY when the free account is locally exhausted
# or Groq returns a 429 rate limit response.
GROQ_FREE_API_KEY=your_free_groq_api_key
# Paid / fallback Groq key. Kept as the primary backwards-compatible env var.
GROQ_API_KEY=your_paid_groq_api_key
# Cloudflare AI Gateway configuration (Required)
# Base URL for CF AI Gateway (e.g., https://gateway.ai.cloudflare.com/v1/ACCOUNT_ID/GATEWAY_NAME/compat)
CF_AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_NAME/compat
# Authorization token for CF AI Gateway
CF_AIG_TOKEN=your_cloudflare_ai_gateway_token

# Monitoring (Required)
ADMIN_CHAT_ID=your_telegram_chat_id_for_admin_reports
FRIENDLY_INSTANCE_NAME=My_Bot_Instance
