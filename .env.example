# Bot Configuration (Required)
# Note: For complex prompts with multiple lines, use \n for line breaks or set via deployment platform UI
BOT_SYSTEM_PROMPT="You are a helpful AI assistant. Define your bot's complete personality here, including who the bot is, main traits, expertise areas, response style, tone, language, behavioral rules, and any specific phrases or expressions the bot uses."
BOT_TRIGGER_WORDS=bot,assistant,help

# Telegram Configuration (Required)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_USERNAME=your_bot_username
WEBHOOK_AUTH_KEY=your_webhook_authentication_key

# Infrastructure (Required)
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
FUNCTION_URL=https://your-app.vercel.app

# Supabase Postgres (Required for AI credits billing)
# Use the pooled connection URL from Supabase (port 6543)
SUPABASE_POSTGRES_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# APIs
COINMARKETCAP_KEY=your_coinmarketcap_api_key
# Giphy API key for /gm and /gn commands (good morning/night GIFs)
# Get one free at: https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key
# Cloudflare AI Gateway (REQUIRED - all AI traffic routes through here)
# 1. Create Gateway: https://dash.cloudflare.com > AI > AI Gateway
# 2. Get Gateway Token: Gateway > Provider Keys > Create Token
# 3. Get Account ID: from the Gateway URL (https://dash.cloudflare.com/.../ai/ai-gateway?id=...)
# The bot uses the /compat endpoint (OpenAI-compatible) for both Workers AI and Groq
CLOUDFLARE_AI_GATEWAY_TOKEN=your_gateway_token
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_AI_GATEWAY_ID=your_gateway_id

# Groq keys (required for /buscar web search via Groq Compound)
# Free key is tried first, falls back to paid on rate limit
GROQ_FREE_API_KEY=your_free_groq_api_key
GROQ_API_KEY=your_paid_groq_api_key
# Webhook runtime safety. Used to dedupe Telegram retries and abort free->paid
# Compound fallbacks when the Vercel request is within the retry safety margin.
WEBHOOK_MAX_RUNTIME_SECONDS=120
WEBHOOK_RETRY_SAFETY_MARGIN_SECONDS=45
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=180
WEBHOOK_FORCE_PAID_RETRY_TTL_SECONDS=300

# AI Credits Billing (defaults shown; always enabled)
AI_ONBOARDING_CREDITS=3.0
AI_STARS_PACKS_JSON='[{"id":"p50","credits":50.0,"xtr":25},{"id":"p100","credits":100.0,"xtr":50},{"id":"p250","credits":250.0,"xtr":125},{"id":"p500","credits":500.0,"xtr":250},{"id":"p1000","credits":1000.0,"xtr":500},{"id":"p2500","credits":2500.0,"xtr":1250}]'


# Monitoring (Required)
ADMIN_CHAT_ID=your_telegram_chat_id_for_admin_reports
FRIENDLY_INSTANCE_NAME=My_Bot_Instance
